+# SPDX-License-Identifier: GPL-2.0-only
+ARCH:=mips
+SUBTARGET:=rtl8197f
+BOARD:=realtek
+BOARDNAME:=Realtek MIPS RTL8197F scaffold
+
+# This subtarget is a clean-room scaffold only. CPU_TYPE is intentionally not
+# set until the RTL8197F CPU/platform path is confirmed from public evidence.
+
+define Target/Description
+	Provisional scaffold for Realtek RTL8197F platform investigation.
+	Not build-validated and not validated on hardware.
+endef
