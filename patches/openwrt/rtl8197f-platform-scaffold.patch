diff --git a/target/linux/realtek/patches-6.18/120-mips-realtek-add-rtl8197f-compatible-scaffold.patch b/target/linux/realtek/patches-6.18/120-mips-realtek-add-rtl8197f-compatible-scaffold.patch
new file mode 100644
index 0000000000..3ba7d528b1
--- /dev/null
+++ b/target/linux/realtek/patches-6.18/120-mips-realtek-add-rtl8197f-compatible-scaffold.patch
@@ -0,0 +1,31 @@
+From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
+From: OpenWrt A2004MU Research <noreply@example.invalid>
+Date: Mon, 29 Jun 2026 00:00:00 +0900
+Subject: [PATCH] MIPS: realtek: add RTL8197F machine compatible scaffold
+
+Add a provisional RTL8197F SoC compatible to the existing Realtek MIPS
+machine match table. This is a clean-room scaffold only and is not
+validated on hardware.
+
+No register map, interrupt, clock, timer, UART, SPI, Ethernet, or switch
+assumptions are added by this patch.
+
+Signed-off-by: OpenWrt A2004MU Research <noreply@example.invalid>
+---
+ arch/mips/generic/board-realtek.c | 5 +++++
+ 1 file changed, 5 insertions(+)
+
+--- a/arch/mips/generic/board-realtek.c
++++ b/arch/mips/generic/board-realtek.c
+@@ -60,6 +60,11 @@ static __init const void *realtek_fixup_
+ }
+ 
+ static const struct of_device_id realtek_of_match[] __initconst = {
++	/*
++	 * Clean-room RTL8197F scaffold only. This compatible is not
++	 * hardware validated and does not imply peripheral support.
++	 */
++	{ .compatible = "realtek,rtl8197f-soc" },
+ 	{ .compatible = "realtek,rtl9302-soc" },
+ 	{}
+ };
diff --git a/target/linux/realtek/patches-6.18/301-mips-realtek-add-rtl8197f-kconfig-scaffold.patch b/target/linux/realtek/patches-6.18/301-mips-realtek-add-rtl8197f-kconfig-scaffold.patch
new file mode 100644
index 0000000000..c4b0fe3375
--- /dev/null
+++ b/target/linux/realtek/patches-6.18/301-mips-realtek-add-rtl8197f-kconfig-scaffold.patch
@@ -0,0 +1,27 @@
+From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
+From: A2004MU OpenWrt Research <noreply@example.invalid>
+Date: Mon, 29 Jun 2026 00:00:00 +0900
+Subject: [PATCH] mips: realtek: add RTL8197F Kconfig scaffold
+
+Add a provisional RTL8197F Kconfig symbol under the existing Realtek MIPS
+machine family. This is a clean-room scaffold only and is not hardware
+validated.
+
+This deliberately does not select RTL838X, RTL839X, RTL930X, or RTL931X, and
+does not add register, IRQ, clock, timer, or driver assumptions.
+---
+--- a/arch/mips/Kconfig
++++ b/arch/mips/Kconfig
+@@ -1086,6 +1086,12 @@ config RTL931X
+ 	select SYS_SUPPORTS_SMP
+ 	select SYS_SUPPORTS_MIPS_CPS
+ 
++config MACH_REALTEK_RTL8197F
++	bool "Realtek RTL8197F scaffold"
++	depends on MACH_REALTEK_RTL
++	help
++	  Clean-room scaffold only; not hardware validated.
++
+ source "arch/mips/alchemy/Kconfig"
+ source "arch/mips/ath25/Kconfig"
+ source "arch/mips/ath79/Kconfig"
diff --git a/target/linux/realtek/rtl8197f/README.md b/target/linux/realtek/rtl8197f/README.md
new file mode 100644
index 0000000000..e313199b1a
--- /dev/null
+++ b/target/linux/realtek/rtl8197f/README.md
@@ -0,0 +1,35 @@
+# RTL8197F Scaffold
+
+This is a clean-room scaffold for RTL8197F investigation.
+
+Status:
+
+* Not hardware validated.
+* Not a complete OpenWrt target.
+* No flash/install instructions.
+* No SDK vendor code.
+* No generated firmware output.
+
+Required unknowns:
+
+* CPU/platform compatibility.
+* Machine compatible.
+* Memory map.
+* UART base/IRQ/clock.
+* Interrupt controller.
+* Timer/clocksource.
+* SPI NOR controller.
+* Ethernet MAC.
+* Switch/PHY/MDIO.
+* GPIO/LED/button.
+* Image recipe.
+
+First milestone:
+
+* Kernel boot log over UART.
+* Then wired LAN + SSH.
+
+Deferred:
+
+* Wi-Fi.
+* LuCI.
diff --git a/target/linux/realtek/rtl8197f/config-6.18 b/target/linux/realtek/rtl8197f/config-6.18
new file mode 100644
index 0000000000..6f5127ec3d
--- /dev/null
+++ b/target/linux/realtek/rtl8197f/config-6.18
@@ -0,0 +1,24 @@
+# SPDX-License-Identifier: GPL-2.0-only
+#
+# Clean-room RTL8197F scaffold only.
+#
+# TODO: Add only independently verified kernel config symbols after the
+# CPU/platform, timer, interrupt, UART, SPI NOR, Ethernet MAC, and switch/PHY
+# paths are confirmed. Do not copy SDK-derived config.
+CONFIG_MACH_REALTEK_RTL=y
+CONFIG_MACH_REALTEK_RTL8197F=y
+# Stock A2004MU UART log reports: CPU revision is 00019385 (MIPS 24Kc).
+# MIPS 24Kc is a MIPS32 Release 2 core.
+# CONFIG_CPU_MIPS32_R1 is not set
+CONFIG_CPU_MIPS32_R2=y
+# Existing target/linux/realtek subtargets use raw appended DTB. This follows
+# the target convention only; the A2004MU DTS remains a scaffold.
+# CONFIG_MIPS_NO_APPENDED_DTB is not set
+CONFIG_MIPS_RAW_APPENDED_DTB=y
+# Existing target/linux/realtek subtargets take kernel arguments from DTB.
+# CONFIG_MIPS_CMDLINE_FROM_BOOTLOADER is not set
+CONFIG_MIPS_CMDLINE_FROM_DTB=y
+# CONFIG_RTL838X is not set
+# CONFIG_RTL839X is not set
+# CONFIG_RTL930X is not set
+# CONFIG_RTL931X is not set
